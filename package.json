{
  "name": "server-central",
  "private": true,
  "workspaces": ["apps/*", "shared"],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:web",
    "dev:server": "bun run --filter @central/server dev",
    "dev:web": "bun run --filter @central/web dev",
    "build": "bun run --filter @central/web build",
    "build:agent:linux": "bash scripts/build-agent.sh linux",
    "build:agent:mac": "bash scripts/build-agent.sh mac",
    "build:agent:windows": "bash scripts/build-agent.sh windows",
    "build:agent": "bash scripts/build-agent.sh",
    "typecheck": "bun run --filter @central/shared typecheck && bun run --filter @central/server typecheck && bun run --filter @central/web typecheck"
  }
}
